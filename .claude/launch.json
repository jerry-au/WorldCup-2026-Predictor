{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend API",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "9000",
        "--reload"
      ],
      "port": 9000,
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Flutter Web",
      "runtimeExecutable": "C:\\Users\\jerry\\flutter\\bin\\flutter.bat",
      "runtimeArgs": [
        "run",
        "-d",
        "chrome",
        "--web-port=9001"
      ],
      "port": 9001,
      "cwd": "${workspaceFolder}/flutter_app"
    }
  ]
}
